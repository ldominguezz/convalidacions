---
// Aquest codi s'executa al servidor (Server-Side Rendering)
import { createClient } from "@supabase/supabase-js";

// Inicialitzem Supabase
const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const supabase = createClient(supabaseUrl, supabaseKey);

// Obtenim tots els cicles de la base de dades, ordenats alfabèticament
const { data: cicles, error } = await supabase
  .from("cicles")
  .select("*")
  .order("llei");

if (error) {
  console.error("Error carregant cicles:", error);
}

const { data: families, error: errorFamilia } = await supabase
  .from("families")
  .select("*")
  .order("nom");

if (errorFamilia) {
  console.error("Error carregant families:", errorFamilia);
}

// Filtrem els de destí perquè només mostri CFGM i CFGS (excloent els Certificats)
const ciclesDesti =
  cicles?.filter(
    (c) => (c.grau === "CFGM" || c.grau === "CFGS") && c.impartit === true,
  ) || [];

// Aquesta és la "fórmula màgica" en Javascript per obtenir valors únics
const lleisUniques = [...new Set(cicles?.map((c) => c.llei))];
---

<div
  class="max-w-5xl mx-auto p-6 bg-white rounded-xl shadow-lg mt-10 border border-gray-100"
>
  <div class="mb-8 text-center">
    <h1 class="text-3xl font-extrabold text-gray-900 tracking-tight">
      Cercador de Convalidacions FP
    </h1>
    <p class="mt-2 text-gray-500">
      Descobreix quins mòduls pots convalidar segons els teus estudis previs.
    </p>
  </div>

  <form
    id="form-convalidacions"
    class="space-y-6 bg-gray-50 p-6 rounded-lg border border-gray-200"
  >
    <!-- Dades personals -->
    <!-- <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label for="nom" class="block text-sm font-semibold text-gray-700 mb-1"
          >Introdueix el teu nom complet</label
        >
        <input
          type="text"
          id="nom"
          name="nom"
          required
          class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 bg-white text-gray-700"
        />
      </div>
      <div>
        <label for="dni" class="block text-sm font-semibold text-gray-700 mb-1"
          >Introdueix el teu dni</label
        >
        <input
          type="text"
          id="dni"
          name="dni"
          required
          class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 bg-white text-gray-700"
        />
      </div>
    </div>
-->
    <!-- Escollir Familia i llei -->
     <!-- 
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-2">
          Informació sobre els estudis
        </h2>
        <label
          for="familiaOrigen"
          class="block text-sm font-semibold text-gray-700 mb-1"
          >De quina familia professional provens?</label
        >
        <select
          id="familiaOrigen"
          name="familiaOrigen"
          required
          class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 bg-white text-gray-700"
        >
          <option value="" disabled selected>-- Selecciona la família --</option
          >
          {families?.map((f) => <option value={f.id_familia}>{f.nom}</option>)}
        </select>
      </div>

      <div>
        <label for="llei" class="block text-sm font-semibold text-gray-700 mb-1"
          >Selecciona la llei</label
        >
        <select
          id="llei"
          name="llei"
          required
          class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 bg-white text-gray-700 border"
        >
          <option value="" disabled selected>-- Selecciona la llei --</option>

          {lleisUniques.map((llei) => <option value={llei}>{llei}</option>)}
        </select>
      </div>
    </div>
    -->
    <!-- Cicles concrets (origen i destí) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div>
        <label
          for="origen"
          class="block text-sm font-semibold text-gray-700 mb-1"
          >Quins estudis aportes? (Origen)</label
        >
        <select
          id="origen"
          name="origen"
          required
          class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 bg-white text-gray-700"
        >
          <option value="" disabled selected
            >-- Selecciona el teu títol previ --</option
          >
          {
            cicles?.map((c) => (
              <option value={c.id_cicle}>
                {c.grau === "CP" ? "[CP] " : `[${c.grau} - ${c.llei}] `}{" "}
                {c.nom}
              </option>
            ))
          }
        </select>
      </div>

      <div>
        <label
          for="desti"
          class="block text-sm font-semibold text-gray-700 mb-1"
          >Què vols estudiar? (Destí)</label
        >
        <select
          id="desti"
          name="desti"
          required
          class="block w-full rounded-md border-gray-300 shadow-sm focus:border-blue-500 focus:ring-blue-500 p-2.5 bg-white text-gray-700 border"
        >
          <option value="" disabled selected
            >-- Selecciona el cicle a cursar --</option
          >
          {
            ciclesDesti.map((c) => (
              <option value={c.id_cicle}>
                {`[${c.grau}]`} - {c.nom}
              </option>
            ))
          }
        </select>
      </div>
    </div>

    <button
      type="submit"
      class="w-full flex justify-center py-3 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-colors"
    >
      Consultar Convalidacions
    </button>
  </form>

  <div id="resultats-container" class="mt-10 hidden">
    <h2 class="text-xl font-bold text-gray-800 mb-4 border-b pb-2">
      Resultat de la consulta
    </h2>

    <div
      class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 rounded-lg"
    >
      <table class="min-w-full divide-y divide-gray-300">
        <thead class="bg-gray-50">
          <tr>
            <th
              scope="col"
              class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900"
              >Mòdul a Convalidar (Destí)</th
            >
            <th
              scope="col"
              class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900"
              >Mòdul Prèvi (Origen)</th
            >
            <th
              scope="col"
              class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900"
              >Regla / Nota</th
            >
          </tr>
        </thead>
        <tbody id="taula-body" class="divide-y divide-gray-200 bg-white">
        </tbody>
      </table>
    </div>

    <div
      id="missatge-buit"
      class="hidden mt-4 p-4 bg-yellow-50 text-yellow-800 rounded-md border border-yellow-200"
    >
      No s'han trobat convalidacions directes per a aquesta combinació de
      cicles.
    </div>
  </div>
</div>

<script>
  import { createClient } from "@supabase/supabase-js";

  // Agafem les variables directament (assegura't que comencen per PUBLIC_)
  const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
  const supabaseKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
  const supabase = createClient(supabaseUrl, supabaseKey);

  const form = document.getElementById(
    "form-convalidacions",
  ) as HTMLFormElement;
  const resultatsContainer = document.getElementById("resultats-container");
  const missatgeBuit = document.getElementById("missatge-buit");
  const taulaBody = document.getElementById(
    "taula-body",
  ) as HTMLTableSectionElement;

  if (form) {
    form?.addEventListener("submit", async (e) => {
      e.preventDefault();

      // Obtenim els valors dels selects
      const origenId = (document.getElementById("origen") as HTMLSelectElement)
        .value;
      const destiId = (document.getElementById("desti") as HTMLSelectElement)
        .value;

      if (!origenId || !destiId) return;

      // Estat visual de càrrega
      resultatsContainer?.classList.remove("hidden");
      missatgeBuit?.classList.add("hidden");

      // Si són el mateix cicle, mostrem un missatge
      if (origenId === destiId) {
        taulaBody.innerHTML =
          '<tr><td colspan="3" class="px-6 py-8 text-center text-gray-500">No es pot comparar el mateix cicle./td></tr>';
        return;
      }

      taulaBody.innerHTML =
        '<tr><td colspan="3" class="px-6 py-8 text-center text-gray-500">Buscant convalidacions...</td></tr>';

      try {
        const { data, error } = await supabase
          .from("convalidacions")
          .select(
            `
          regla_nota,
          modul_desti:moduls!id_modul_desti(codi_modul, nom),
          modul_origen:moduls!id_modul_origen(nom)
        `,
          )
          .eq("id_cicle_origen", origenId)
          .eq("id_cicle_desti", destiId);

        if (error) {
        
          console.error("Error de Supabase:", error.message);
          throw error;
        }

        taulaBody.innerHTML = "";

        if (!data || data.length === 0) {
          missatgeBuit?.classList.remove("hidden");
          // Opcional: amagar la taula si no hi ha dades
          return;
        }

        data.forEach((fila: any) => {
          const mDesti = Array.isArray(fila.modul_desti)
            ? fila.modul_desti[0]
            : fila.modul_desti;
          const mOrigen = Array.isArray(fila.modul_origen)
            ? fila.modul_origen[0]
            : fila.modul_origen;

          const textDesti = mDesti
            ? `<strong>${mDesti.codi_modul}</strong> - ${mDesti.nom}`
            : "Mòdul desconegut";

          const textOrigen = mOrigen
            ? mOrigen.nom
            : '<span class="italic text-gray-400">Títol complet aportat</span>';

          // --- LÒGICA PER A LA COLUMNA DE LA DRETA (NOTES) ---
          let badgeNota = "";
          if (fila.regla_nota === "CINC") {
            badgeNota =
              '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">5 (CV)</span>';
          } else if (fila.regla_nota === "MATEIXA_NOTA") {
            badgeNota =
              '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">Nota del mòdul</span>';
          } else if (fila.regla_nota === "MITJANA_CICLE") {
            badgeNota =
              '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-purple-100 text-purple-800">Nota mitjana cicle</span>';
          } else {
            // Si no coincideix amb cap, mostrem el text tal qual o un per defecte
            badgeNota = `<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">${fila.regla_nota || "Consultar"}</span>`;
          }

          const tr = document.createElement("tr");
          tr.innerHTML = `
    <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm text-gray-900">${textDesti}</td>
    <td class="whitespace-nowrap px-3 py-4 text-sm text-gray-500">${textOrigen}</td>
    <td class="whitespace-nowrap px-3 py-4 text-sm">${badgeNota}</td>
  `;
          taulaBody?.appendChild(tr);
        });
      } catch (err) {
        const errorMessage = err instanceof Error ? err.message : String(err);
        taulaBody.innerHTML = `<tr><td colspan="3" class="px-6 py-8 text-center text-red-500">Error: ${errorMessage}</td></tr>`;
      }
    });
  }
</script>
